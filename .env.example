# ─────────────────────────────────────────────────────────────────
# StemNest Academy — Environment Variables
# Copy this file to backend/.env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── Server ──
PORT=3000
NODE_ENV=development

# ── Database (AWS RDS PostgreSQL) ──
DATABASE_URL=postgresql://stemnest_user:your_password@your-rds-endpoint.eu-west-2.rds.amazonaws.com:5432/stemnest

# ── Authentication ──
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex_string
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── Password Reset ──
RESET_TOKEN_EXPIRES_MINS=30

# ── AWS (for SES email + S3 file storage) ──
AWS_REGION=eu-west-2
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=stemnest-site

# ── Email via AWS SES ──
EMAIL_FROM=no-reply@stemnestacademy.co.uk
EMAIL_FROM_NAME=StemNest Academy
# For local dev you can use SMTP instead:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_app_password

# ── WhatsApp via Twilio ──
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Payments (Stripe) ──
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── Frontend URL (for CORS) ──
FRONTEND_URL=https://stemnestacademy.co.uk
# For local dev:
# FRONTEND_URL=http://localhost:5500

# ── App URL (used in email links) ──
APP_URL=https://stemnestacademy.co.uk

# ── Whereby (video rooms) ──
WHEREBY_API_KEY=your_whereby_api_key

# ── Logging ──
LOG_LEVEL=info
